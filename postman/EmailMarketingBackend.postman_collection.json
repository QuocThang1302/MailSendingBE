      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Register success', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "const json = pm.response.json();",
              "if (json && json.data) {",
              "  pm.collectionVariables.set('token', json.data.token || '');",
